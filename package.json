    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "^16.1.6",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.49",
    "start-server-and-test": "^3.0.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  }
